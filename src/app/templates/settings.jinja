{% extends "base.jinja" %}

{% block title %}Settings — PerformanceLens{% endblock %}
{% block page_title %}Settings{% endblock %}

{% block content %}
<div class="max-w-2xl space-y-8 pb-16">
  <header class="rounded-xl border border-slate-800 bg-[#0F172A] px-4 py-5 sm:px-6">
    <p class="text-xs font-semibold uppercase tracking-wider text-cyan-400/90">Local app</p>
    <h2 class="font-display mt-1 text-xl font-bold text-white sm:text-2xl">Settings &amp; data</h2>
    <p class="mt-2 text-sm text-slate-400 leading-relaxed">
      PerformanceLens keeps everything in a SQLite file on this device. Export a backup before major changes. For a Tauri or Electron shell, point the webview at this app and set
      <code class="rounded bg-slate-900 px-1.5 py-0.5 text-xs text-cyan-200/90">PERFORMANCELENS_DB_PATH</code>
      if you want the database next to your app bundle.
    </p>
  </header>

  <div id="settings-msg" class="hidden rounded-lg border px-4 py-3 text-sm" role="status" aria-live="polite"></div>

  <section class="rounded-xl border border-slate-800/50 bg-[#0F172A] p-5 sm:p-6" aria-labelledby="prof-heading">
    <h2 id="prof-heading" class="font-display text-lg font-bold text-white">Profile</h2>
    <p class="mt-1 text-xs text-slate-500">Shown in the sidebar and dashboard greeting.</p>
    <form id="form-profile" class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end">
      <div class="min-w-0 flex-1">
        <label for="set-name" class="block text-xs font-semibold text-slate-500">Display name</label>
        <input type="text" id="set-name" name="name" value="{{ user_display_name }}" maxlength="120" autocomplete="name"
          class="mt-1 w-full min-h-[44px] rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-base text-white placeholder:text-slate-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400" />
      </div>
      <button type="submit" class="min-h-[44px] shrink-0 rounded-lg bg-cyan-400 px-5 py-2.5 text-sm font-bold text-[#0B1120] hover:bg-cyan-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300">
        Save name
      </button>
    </form>
  </section>

  <section class="rounded-xl border border-slate-800/50 bg-[#0F172A] p-5 sm:p-6" aria-labelledby="pin-heading">
    <h2 id="pin-heading" class="font-display text-lg font-bold text-white">Change PIN</h2>
    <p class="mt-1 text-xs text-slate-500">Four digits. You will still enter it each time you open the app.</p>
    <form id="form-pin" class="mt-4 grid gap-3 sm:grid-cols-3">
      <div>
        <label for="pin-current" class="block text-xs font-semibold text-slate-500">Current PIN</label>
        <input type="password" id="pin-current" inputmode="numeric" maxlength="4" pattern="[0-9]*" autocomplete="current-password"
          class="mt-1 w-full min-h-[44px] rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-base text-white tabular-nums tracking-widest focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400" />
      </div>
      <div>
        <label for="pin-new" class="block text-xs font-semibold text-slate-500">New PIN</label>
        <input type="password" id="pin-new" inputmode="numeric" maxlength="4" pattern="[0-9]*" autocomplete="new-password"
          class="mt-1 w-full min-h-[44px] rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-base text-white tabular-nums tracking-widest focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400" />
      </div>
      <div>
        <label for="pin-new2" class="block text-xs font-semibold text-slate-500">Confirm new PIN</label>
        <input type="password" id="pin-new2" inputmode="numeric" maxlength="4" pattern="[0-9]*" autocomplete="new-password"
          class="mt-1 w-full min-h-[44px] rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-base text-white tabular-nums tracking-widest focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400" />
      </div>
      <div class="sm:col-span-3">
        <button type="submit" class="min-h-[44px] rounded-lg border border-slate-600 bg-slate-800/50 px-5 py-2.5 text-sm font-semibold text-slate-200 hover:border-cyan-500/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-300">
          Update PIN
        </button>
      </div>
    </form>
  </section>

  <section class="rounded-xl border border-slate-800/50 bg-[#0F172A] p-5 sm:p-6" aria-labelledby="data-heading">
    <h2 id="data-heading" class="font-display text-lg font-bold text-white">Backup</h2>
    <p class="mt-1 text-xs text-slate-500">Download JSON with results, subjects, marking scheme, and study planner data (PDFs as base64). Restore is not automated yet — keep this file safe.</p>
    <a href="{{ url_for('main.api_export_json') }}" download
      class="mt-4 inline-flex min-h-[44px] items-center justify-center gap-2 rounded-lg border border-cyan-500/40 bg-cyan-500/10 px-5 py-3 text-sm font-semibold text-cyan-300 hover:bg-cyan-500/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400">
      <i class="fa-solid fa-download" aria-hidden="true"></i>
      Download backup (.json)
    </a>
  </section>

  <section class="rounded-xl border border-red-500/20 bg-red-950/20 p-5 sm:p-6" aria-labelledby="danger-heading">
    <h2 id="danger-heading" class="font-display text-lg font-bold text-red-200">Danger zone</h2>
    <p class="mt-1 text-xs text-red-200">Removes every saved grade, subject list, and planner schedule on this device. Your account and PIN stay; you can add data again from Manage results.</p>
    <form id="form-reset" class="mt-4 space-y-3">
      <div>
        <label for="reset-pin" class="block text-xs font-semibold text-red-200">Confirm with PIN</label>
        <input type="password" id="reset-pin" inputmode="numeric" maxlength="4" pattern="[0-9]*" autocomplete="current-password"
          class="mt-1 w-full max-w-xs min-h-[44px] rounded-lg border border-red-500/30 bg-slate-950 px-3 py-2 text-base text-white tabular-nums tracking-widest focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-400" />
      </div>
      <label class="flex cursor-pointer items-start gap-2 text-sm text-red-100/90">
        <input type="checkbox" id="reset-ack" class="mt-1 h-4 w-4 rounded border-red-500/50 bg-slate-900 text-red-500" />
        <span>I understand this cannot be undone without a backup file.</span>
      </label>
      <button type="submit" class="min-h-[44px] rounded-lg border border-red-500/50 bg-red-500/15 px-5 py-2.5 text-sm font-bold text-red-200 hover:bg-red-500/25 focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-400">
        Erase all results &amp; planner data
      </button>
    </form>
  </section>

  <section class="rounded-xl border border-slate-800/50 bg-[#0F172A] p-5 sm:p-6" aria-labelledby="sess-heading">
    <h2 id="sess-heading" class="font-display text-lg font-bold text-white">Session</h2>
    <p class="mt-1 text-xs text-slate-500">Manage your current browser session. End session requires PIN re-entry but keeps your account.</p>
    <div class="mt-4 space-y-3">
      <button type="button" id="btn-end-session" class="min-h-[44px] w-full rounded-lg border border-amber-500/40 bg-amber-500/10 px-5 py-2.5 text-sm font-semibold text-amber-300 hover:bg-amber-500/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-amber-400">
        <i class="fa-solid fa-clock mr-2" aria-hidden="true"></i>End current session
      </button>
      <button type="button" id="btn-logout" class="min-h-[44px] w-full rounded-lg border border-slate-600 bg-slate-800/40 px-5 py-2.5 text-sm font-semibold text-slate-200 hover:border-slate-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400">
        <i class="fa-solid fa-right-from-bracket mr-2" aria-hidden="true"></i>Sign out completely
      </button>
    </div>
    <div class="mt-3 p-3 rounded-lg border border-slate-700/50 bg-slate-900/50">
      <p class="text-xs text-slate-400">
        <strong class="text-amber-300">End session:</strong> Clears PIN unlock, requires re-entry (keeps account)<br>
        <strong class="text-red-300">Sign out:</strong> Clears everything, forces re-onboarding (deletes session data)
      </p>
    </div>
  </section>
</div>
{% endblock %}

{% block scripts %}
<script>
(function () {
  'use strict';

  var msgEl = document.getElementById('settings-msg');

  function showMsg(text, kind) {
    if (window.toast) {
      window.toast({ text: text || '', kind: kind === 'warn' ? 'warn' : (kind === 'error' ? 'error' : 'ok') });
      return;
    }
    if (!msgEl) return;
    msgEl.textContent = text || '';
    msgEl.classList.remove('hidden', 'border-emerald-500/30', 'bg-emerald-500/10', 'text-emerald-200', 'border-red-500/30', 'bg-red-500/10', 'text-red-200', 'border-amber-500/30', 'bg-amber-500/10', 'text-amber-200');
    msgEl.classList.add('hidden');
    if (!text) return;
    msgEl.classList.remove('hidden');
    if (kind === 'error') {
      msgEl.classList.add('border-red-500/30', 'bg-red-500/10', 'text-red-200');
      msgEl.setAttribute('role', 'alert');
    } else if (kind === 'warn') {
      msgEl.classList.add('border-amber-500/30', 'bg-amber-500/10', 'text-amber-200');
      msgEl.setAttribute('role', 'status');
    } else {
      msgEl.classList.add('border-emerald-500/30', 'bg-emerald-500/10', 'text-emerald-200');
      msgEl.setAttribute('role', 'status');
    }
  }

  function parseJson(res) {
    return res.text().then(function (t) {
      try {
        return JSON.parse(t);
      } catch (e) {
        return { message: t || 'Request failed.' };
      }
    });
  }

  document.getElementById('form-profile').addEventListener('submit', function (ev) {
    ev.preventDefault();
    var name = (document.getElementById('set-name').value || '').trim();
    if (!name) {
      showMsg('Enter a display name.', 'error');
      return;
    }
    fetch('{{ url_for("main.api_settings_profile") }}', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: name }),
    })
      .then(function (r) {
        return parseJson(r).then(function (j) {
          return { ok: r.ok, j: j };
        });
      })
      .then(function (x) {
        if (!x.ok) {
          showMsg(x.j.message || 'Could not save name.', 'error');
          return;
        }
        showMsg('Name saved. Refresh other tabs if the sidebar still shows the old name.', 'ok');
        var ini = document.getElementById('sidebarUserInitial');
        var nm = document.getElementById('sidebarUserName');
        if (ini) ini.textContent = name.charAt(0).toUpperCase();
        if (nm) nm.textContent = name;
      })
      .catch(function () {
        showMsg('Network error.', 'error');
      });
  });

  document.getElementById('form-pin').addEventListener('submit', function (ev) {
    ev.preventDefault();
    var a = (document.getElementById('pin-current').value || '').replace(/\D/g, '').slice(0, 4);
    var b = (document.getElementById('pin-new').value || '').replace(/\D/g, '').slice(0, 4);
    var c = (document.getElementById('pin-new2').value || '').replace(/\D/g, '').slice(0, 4);
    if (a.length !== 4 || b.length !== 4) {
      showMsg('Enter current and new 4-digit PINs.', 'error');
      return;
    }
    if (b !== c) {
      showMsg('New PIN and confirmation do not match.', 'error');
      return;
    }
    fetch('{{ url_for("main.api_settings_pin") }}', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ current_pin: a, new_pin: b }),
    })
      .then(function (r) {
        return parseJson(r).then(function (j) {
          return { ok: r.ok, j: j };
        });
      })
      .then(function (x) {
        if (!x.ok) {
          showMsg(x.j.message || 'Could not change PIN.', 'error');
          return;
        }
        document.getElementById('pin-current').value = '';
        document.getElementById('pin-new').value = '';
        document.getElementById('pin-new2').value = '';
        showMsg('PIN updated.', 'ok');
      })
      .catch(function () {
        showMsg('Network error.', 'error');
      });
  });

  document.getElementById('form-reset').addEventListener('submit', function (ev) {
    ev.preventDefault();
    if (!document.getElementById('reset-ack').checked) {
      showMsg('Check the box to confirm you understand.', 'warn');
      return;
    }
    var pin = (document.getElementById('reset-pin').value || '').replace(/\D/g, '').slice(0, 4);
    if (pin.length !== 4) {
      showMsg('Enter your PIN to erase data.', 'error');
      return;
    }
    if (!window.confirm('Erase all results and planner data on this device?')) return;
    fetch('{{ url_for("main.api_settings_reset_data") }}', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ confirm: 'RESET', pin: pin }),
    })
      .then(function (r) {
        return parseJson(r).then(function (j) {
          return { ok: r.ok, j: j };
        });
      })
      .then(function (x) {
        if (!x.ok) {
          showMsg(x.j.message || 'Reset failed.', 'error');
          return;
        }
        document.getElementById('reset-pin').value = '';
        document.getElementById('reset-ack').checked = false;
        showMsg(x.j.message || 'Data cleared.', 'ok');
      })
      .catch(function () {
        showMsg('Network error.', 'error');
      });
  });

  document.getElementById('btn-end-session').addEventListener('click', function () {
    fetch('{{ url_for("main.api_session_end") }}', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: '{}',
    })
      .then(function (response) {
        return response.json();
      })
      .then(function (data) {
        showMsg(data.message || 'Session ended', 'ok');
        setTimeout(function() {
          window.location.href = '{{ url_for("main.unlock_page") }}';
        }, 1000);
      })
      .catch(function () {
        showMsg('Network error', 'error');
      });
  });

  document.getElementById('btn-logout').addEventListener('click', function () {
    if (confirm('Sign out completely? This will clear all session data and require re-onboarding.')) {
      fetch('{{ url_for("main.api_logout") }}', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: '{}',
      })
        .then(function () {
          window.location.href = '{{ url_for("main.home") }}';
        })
        .catch(function () {
          window.location.href = '{{ url_for("main.home") }}';
        });
    }
  });
})();
</script>
{% endblock %}
