{% extends "base.jinja" %}

{% block title %}About — PerformanceLens{% endblock %}
{% block page_title %}About{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="rounded-xl border border-slate-800 gl-card p-6 sm:p-8">
    <div class="mb-6">
      <h1 class="font-display text-2xl font-bold text-white mb-4">About PerformanceLens</h1>
      
      <div class="space-y-4 text-slate-300">
        <div>
          <h2 class="text-lg font-semibold text-white mb-2">What is PerformanceLens?</h2>
          <p class="text-slate-400 leading-relaxed">
            PerformanceLens is a comprehensive academic performance tracking application designed to help students monitor, analyze, and improve their grades over time. Built with modern web technologies, it provides detailed insights into your academic progress through interactive charts and data visualization.
          </p>
        </div>
        
        <div>
          <h2 class="text-lg font-semibold text-white mb-2">Key Features</h2>
          <ul class="space-y-2 text-slate-400">
            <li class="flex items-start gap-2">
              <i class="fa-solid fa-chart-line text-cyan-400 mt-1" aria-hidden="true"></i>
              <div>
                <strong class="text-white">Grade Tracking</strong>
                <p class="text-sm text-slate-500">Monitor your performance across multiple terms and subjects</p>
              </div>
            </li>
            <li class="flex items-start gap-2">
              <i class="fa-solid fa-magnifying-glass-chart text-cyan-400 mt-1" aria-hidden="true"></i>
              <div>
                <strong class="text-white">Data Analysis</strong>
                <p class="text-sm text-slate-500">Visualize trends and identify areas for improvement</p>
              </div>
            </li>
            <li class="flex items-start gap-2">
              <i class="fa-solid fa-calendar-check text-cyan-400 mt-1" aria-hidden="true"></i>
              <div>
                <strong class="text-white">Study Planning</strong>
                <p class="text-sm text-slate-500">Generate optimized study schedules</p>
              </div>
            </li>
            <li class="flex items-start gap-2">
              <i class="fa-solid fa-list-check text-cyan-400 mt-1" aria-hidden="true"></i>
              <div>
                <strong class="text-white">Recommendations</strong>
                <p class="text-sm text-slate-500">Get personalized improvement suggestions</p>
              </div>
            </li>
          </ul>
        </div>
        
        <div>
          <h2 class="text-lg font-semibold text-white mb-2">About NYSH</h2>
          <p class="text-slate-400 leading-relaxed">
            This application is developed in partnership with the National Youth Science Club (NYSH), combining academic performance tracking with modern technology to help students achieve their educational goals.
          </p>
        </div>
        
        <div>
          <h2 class="text-lg font-semibold text-white mb-2">Version</h2>
          <p class="text-slate-400">
            PerformanceLens v1.0 - Built with Flask, Chart.js, and Tailwind CSS
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
