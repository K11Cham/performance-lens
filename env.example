# Copy to .env and load in your shell, or export manually.
# Tauri/Electron: set these in the shell that starts the embedded server, or in your native wrapper.

# Required for packaged builds (change from the dev default)
# PERFORMANCELENS_SECRET_KEY=use-openssl-rand-hex-32

# SQLite file (default: performance.db next to the project root when running from repo)
# PERFORMANCELENS_DB_PATH=/path/to/performance.db

# Dev server (src/run.py)
# PERFORMANCELENS_DEBUG=true
# PERFORMANCELENS_HOST=127.0.0.1
# PERFORMANCELENS_PORT=5000
