# Environment Configuration
# Copy this file to .env and adjust values for your deployment

# Flask Environment
FLASK_ENV=production

# Security
PERFORMANCELENS_SECRET_KEY=your-secret-key-here-change-this-in-production

# Database (optional - defaults to local file)
# PERFORMANCELENS_DB_PATH=/path/to/your/database.db

# Development Settings (only used when FLASK_ENV=development)
# ALLOW_DEV_SESSION=true
